<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.kotlinpj1.infrastructure.mapper.MemberMapper">

    <select id="findById" resultType="com.example.kotlinpj1.domain.model.Member">
        SELECT id, name
        FROM member
        WHERE id = #{id}
    </select>

</mapper>
